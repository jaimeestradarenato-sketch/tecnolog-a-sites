<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tu Negocio</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}

body {
    background: #0f172a;
    color: white;
}

/* NAV */
nav {
    display: flex;
    justify-content: space-between;
    padding: 20px 40px;
    background: rgba(0,0,0,0.5);
    position: sticky;
    top: 0;
}

nav h1 {
    color: #38bdf8;
}

nav a {
    color: white;
    margin-left: 20px;
    text-decoration: none;
}

/* HERO */
.hero {
    height: 90vh;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    background: linear-gradient(to right, #0f172a, #1e293b);
}

.hero h2 {
    font-size: 3rem;
}

.hero span {
    color: #38bdf8;
}

.btn {
    margin-top: 20px;
    padding: 15px 30px;
    background: #38bdf8;
    border-radius: 8px;
    text-decoration: none;
    color: black;
    font-weight: bold;
}

/* SECCIONES */
.section {
    padding: 80px 20px;
    text-align: center;
}

.services {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
}

.card {
    background: #1e293b;
    margin: 15px;
    padding: 30px;
    border-radius: 15px;
    width: 280px;
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-10px);
    background: #334155;
}

/* GALERÍA */
.gallery img {
    width: 300px;
    margin: 10px;
    border-radius: 10px;
}

/* FOOTER */
footer {
    background: #020617;
    padding: 20px;
    text-align: center;
}

/* RESPONSIVE */
@media(max-width:768px){
    .hero h2 {
        font-size: 2rem;
    }
}
</style>
</head>

<body>

<nav>
    <h1>Tu Negocio</h1>
    <div>
        <a href="#servicios">Servicios</a>
        <a href="#galeria">Galería</a>
        <a href="#contacto">Contacto</a>
    </div>
</nav>

<section class="hero">
    <div>
        <h2>Haz crecer tu <span>negocio</span></h2>
        <p>Calidad, confianza y resultados reales</p>
        <a href="#contacto" class="btn">Contáctanos</a>
    </div>
</section>

<section id="servicios" class="section">
    <h2>Servicios</h2>
    <div class="services">
        <div class="card">
            <h3>Servicio 1</h3>
            <p>Describe aquí tu servicio principal.</p>
        </div>

        <div class="card">
            <h3>Servicio 2</h3>
            <p>Otro servicio importante.</p>
        </div>

        <div class="card">
            <h3>Servicio 3</h3>
            <p>Algo que te haga destacar.</p>
        </div>
    </div>
</section>

<section id="galeria" class="section">
    <h2>Galería</h2>
    <div class="gallery">
        <img src="https://via.placeholder.com/300">
        <img src="https://via.placeholder.com/300">
        <img src="https://via.placeholder.com/300">
    </div>
</section>

<section id="contacto" class="section">
    <h2>Contacto</h2>
    <p>Escríbenos directamente por WhatsApp</p>
    <a class="btn" href="https://wa.me/521XXXXXXXXXX" target="_blank">
        Enviar mensaje
    </a>
</section>

<footer>
    <p>© 2026 Tu Negocio</p>
</footer>

</body>
</html>
